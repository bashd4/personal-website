---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const items = (await getCollection('essays', ({ data }) => !data.draft))
  .sort((a,b)=> (+b.data.date - +a.data.date) || a.id.localeCompare(b.id));
---
<BaseLayout title="Essays — Ben Ashdown">
  <h1>Essays</h1>
  {items.length === 0
    ? <p style="color:var(--soft)">Nothing here yet.</p>
    : <ul style="list-style:none;padding:0;margin:0">{items.map(p => (
        <li style="border-top:1px solid var(--edge);padding:18px 0">
          <h2 style="margin:0 0 3px;font-size:19px"><a href={`/essays/${p.id}`} style="text-decoration:none;color:var(--ink)">{p.data.title}</a></h2>
          <p style="margin:0 0 4px">{p.data.summary}</p>
          <p style="margin:0;color:var(--soft);font-size:13px"><time datetime={p.data.date.toISOString()}>{p.data.date.toLocaleDateString('en-GB',{year:'numeric',month:'short'})}</time></p>
        </li>))}</ul>}
</BaseLayout>
