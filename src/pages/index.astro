---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Ben Ashdown">
  <section class="hero">
    <img class="portrait" src="/portrait.jpg" alt="Ben Ashdown, smiling in front of a city skyline" width="320" height="320" />
    <h1>Ben Ashdown</h1>
    <p class="role">Software engineer</p>
    <p class="line">I build things, read more than I should, and keep the words worth keeping. Welcome in.</p>
    <p class="social"><a href="https://github.com/bashd4">GitHub</a> · <a href="https://www.linkedin.com/in/benjamin-ashdown/">LinkedIn</a> · <a href="mailto:ben99944@gmail.com">Email</a></p>
  </section>
</BaseLayout>
<style>
  .hero{min-height:74vh;display:flex;flex-direction:column;justify-content:center;text-align:left}
  .hero .portrait{width:104px;height:104px;border-radius:50%;object-fit:cover;margin:0 0 20px;box-shadow:0 0 0 1px var(--edge),0 1px 8px rgba(42,39,34,.08)}
  .hero h1{font-size:clamp(44px,8vw,78px);margin:0;letter-spacing:-.02em}
  .hero .role{font-family:var(--font-serif);font-size:22px;color:var(--soft);margin:4px 0 18px}
  .hero .line{font-size:17px;max-width:42ch;margin:0 0 22px}
  .hero .social{font-size:13px}
</style>
